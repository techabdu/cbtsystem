APP_NAME="CBT System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_LEVEL=warning

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cbt_online
# DB_USERNAME=cbt_user
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: SESSION_DOMAIN=.your-domain.com

SANCTUM_STATEFUL_DOMAINS=localhost:3000
# Production: SANCTUM_STATEFUL_DOMAINS=your-domain.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Production: QUEUE_CONNECTION=redis

CACHE_STORE=database
# Production: CACHE_STORE=redis

CORS_ALLOWED_ORIGINS=http://localhost:3000
# Production: CORS_ALLOWED_ORIGINS=https://your-domain.com

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
# Production: MAIL_MAILER=smtp with real SMTP credentials

# Seeder passwords (change before running seeders in production)
SEED_ADMIN_PASSWORD=Admin@123456
SEED_LECTURER_PASSWORD=Lecturer@123456
SEED_STUDENT_PASSWORD=Student@123456

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
